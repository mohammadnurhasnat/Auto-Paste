বুকমার্কলেট কোড:
নিচের পুরো কোডটি কপি করে আপনার বুকমার্কের URL বক্সে বসিয়ে দিন:

// ==UserScript==
// @name         Universal Auto Paste Mode (One-Time Paste)
// @namespace    http://tampermonkey.net/
// @version      4.0
// @description  Smaller, draggable auto paste button with one-time paste function
// @author       Gemini
// @match        *://*/*
// @grant        none
// ==UserScript==

(function() {
'use strict';
var btn = document.createElement('button');
btn.id = 'auto-paste-toggle-btn';
btn.style.position = 'fixed';

var savedLeft = localStorage.getItem('autoPasteBtnLeft');
var savedTop = localStorage.getItem('autoPasteBtnTop');
if (savedLeft && savedTop) {
    btn.style.left = savedLeft;
    btn.style.top = savedTop;
} else {
    btn.style.top = '15px';
    btn.style.right = '15px';
}

btn.style.zIndex = '2147483647';
btn.style.padding = '4px 8px'; 
btn.style.borderRadius = '12px'; 
btn.style.border = 'none';
btn.style.color = '#fff';
btn.style.fontWeight = 'bold';
btn.style.cursor = 'grab'; 
btn.style.boxShadow = '0 2px 5px rgba(0,0,0,0.4)';
btn.style.fontFamily = 'system-ui, -apple-system, sans-serif';
btn.style.fontSize = '11px'; 
btn.style.opacity = '0.75';
btn.style.userSelect = 'none';

var isEnabled = localStorage.getItem('autoPasteEnabled') === 'true';

function updateUI() {
    if (isEnabled) {
        btn.innerText = 'Paste: ON';
        btn.style.backgroundColor = '#28a745';
    } else {
        btn.innerText = 'Paste: OFF';
        btn.style.backgroundColor = '#dc3545';
    }
}
updateUI();
document.body.appendChild(btn);

var isDragging = false;
var hasMoved = false;
var offsetX, offsetY;

btn.addEventListener('mousedown', function(e) {
    isDragging = true;
    hasMoved = false;
    offsetX = e.clientX - btn.getBoundingClientRect().left;
    offsetY = e.clientY - btn.getBoundingClientRect().top;
    btn.style.cursor = 'grabbing';
    btn.style.opacity = '1';
});

document.addEventListener('mousemove', function(e) {
    if (isDragging) {
        hasMoved = true;
        btn.style.left = (e.clientX - offsetX) + 'px';
        btn.style.top = (e.clientY - offsetY) + 'px';
        btn.style.right = 'auto';
    }
});

document.addEventListener('mouseup', function() {
    if (isDragging) {
        isDragging = false;
        btn.style.cursor = 'grab';
        btn.style.opacity = '0.75';
        localStorage.setItem('autoPasteBtnLeft', btn.style.left);
        localStorage.setItem('autoPasteBtnTop', btn.style.top);
    }
});

// অটো-পেস্টিং ও ক্লিপবোর্ড মোছার লজিক
var autoPasteHandler = async function(e) {
    if (!isEnabled || isDragging || hasMoved) return;
    
    var target = e.target;
    var isTextBox = target.tagName === 'TEXTAREA' || 
                    (target.tagName === 'INPUT' && 
                     target.type !== 'button' && 
                     target.type !== 'submit' && 
                     target.type !== 'image' && 
                     target.type !== 'checkbox' && 
                     target.type !== 'radio');

    if (isTextBox) {
        try {
            const text = await navigator.clipboard.readText();
            // ক্লিপবোর্ড যদি খালি না থাকে তবেই পেস্ট হবে
            if (text && text.trim() !== "") {
                target.value = text;
                target.dispatchEvent(new Event('input', { bubbles: true }));
                target.dispatchEvent(new Event('change', { bubbles: true }));
                
                // ১ বার পেস্ট হওয়ার সাথে সাথেই ক্লিপবোর্ড ডিলিট/মুছে ফেলার কোড
                await navigator.clipboard.writeText('');
                console.log('Paste Done & Clipboard Cleared!');
            }
        } catch (err) {
            console.error('Clipboard error:', err);
        }
    }
};
document.addEventListener('click', autoPasteHandler, true);

btn.addEventListener('click', function(e) {
    e.stopPropagation();
    if (hasMoved) return;
    isEnabled = !isEnabled;
    localStorage.setItem('autoPasteEnabled', isEnabled);
    updateUI();
});
})();
