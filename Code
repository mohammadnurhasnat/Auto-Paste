বুকমার্কলেট কোড:
নিচের পুরো কোডটি কপি করে আপনার বুকমার্কের URL বক্সে বসিয়ে দিন:

javascript:(function(){window.__autoPasteEnabled=!window.__autoPasteEnabled;var id='auto-paste-ind';var exp=document.getElementById(id);if(exp)exp.remove();if(window.__autoPasteEnabled){var ind=document.createElement('div');ind.id=id;ind.innerHTML='Auto-Paste: ON';ind.style.position='fixed';ind.style.top='20px';ind.style.right='20px';ind.style.backgroundColor='#28a745';ind.style.color='#fff';ind.style.padding='8px 15px';ind.style.borderRadius='20px';ind.style.zIndex='100000';ind.style.fontFamily='Arial,sans-serif';ind.style.fontSize='13px';ind.style.fontWeight='bold';ind.style.boxShadow='0 4px 6px rgba(0,0,0,0.1)';ind.style.pointerEvents='none';document.body.appendChild(ind);window.__autoPasteHandler=async function(e){if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'){try{const text=await navigator.clipboard.readText();e.target.value=text;e.target.dispatchEvent(new Event('input',{bubbles:true}));e.target.dispatchEvent(new Event('change',{bubbles:true}));}catch(err){console.error(err);}}};document.addEventListener('click',window.__autoPasteHandler,true);}else{document.removeEventListener('click',window.__autoPasteHandler,true);}})();
